# Copy on the VPS:
#   cp .env.production.example .env.production
#   nano .env.production

# Required — generate on server: openssl rand -base64 32
AUTH_SECRET=change-me-use-openssl-rand-base64-32

# Public HTTPS URL (no trailing slash)
NEXTAUTH_URL=https://modernitygate.com

# SQLite inside Docker volume (do not change)
DATABASE_URL=file:/app/prisma/prod.db

# Demo login buttons on /login (set false for public production)
SHOW_DEMO_ACCOUNTS=false

# Run seed once on first deploy only, then set to false
SEED_ON_START=false

# Optional: Google Translate API
# GOOGLE_TRANSLATE_API_KEY=
