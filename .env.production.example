# Copy to .env.production on the VPS and fill in values:
#   cp .env.production.example .env.production

# Required — generate: openssl rand -base64 32
AUTH_SECRET=change-me-use-openssl-rand-base64-32

# Public URL of the app (IP or domain + port 9000)
NEXTAUTH_URL=http://YOUR_SERVER_IP:9000

# SQLite database path inside the container (do not change unless you know why)
DATABASE_URL=file:/app/prisma/prod.db

# Show one-click demo login buttons (set to false before public launch)
SHOW_DEMO_ACCOUNTS=true

# Set to true only on first deploy to create demo users, then set back to false
SEED_ON_START=false
